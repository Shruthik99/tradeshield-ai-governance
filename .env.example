# TradeShield Environment Variables
# Copy this file to .env and fill in your real keys
# NEVER commit .env to git

# Google Gemini API Key (from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-gemini-api-key-here

# Arize Phoenix Cloud
PHOENIX_API_KEY=your-phoenix-api-key-here
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/shruthikashetty2309/v1/traces

# Project settings
TRADESHIELD_ENV=development
